{
    "version": "2.0",
    "telemetryMode": "OpenTelemetry",
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            },
            "enableLiveMetricsFilters": true
        },
        "logLevel": {
            "default": "Information",
            "Host": "Information",
            "Function": "Information"
        }
    },
    "extensions": {
        "serviceBus": {
            "autoCompleteMessages": true
        },
        "durableTask": {
            "tracing": {
                "distributedTracingEnabled": true,
                "version": "V2"
            }
        }
    }
}
